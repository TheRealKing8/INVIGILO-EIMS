# Local development defaults. Copy to .env and adjust as needed.
# DO NOT commit a real .env file.

# --- Runtime -----------------------------------------------------------------
APP_ENV=dev
APP_NAME=invigilo
APP_URL=http://localhost:8080
TZ=UTC

# --- Database ----------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=invigilo
POSTGRES_USER=invigilo
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://invigilo:postgres@postgres:5432/invigilo

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Django ------------------------------------------------------------------
DJANGO_SECRET_KEY=dev-insecure-replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- JWT ---------------------------------------------------------------------
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7
JWT_SIGNING_KEY=dev-jwt-signing-key-replace-me
JWT_ISSUER=invigilo

# --- Email -------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_FROM=noreply@invigilo.local

# --- Password policy (mirrors AC-AUTH-PWD) -----------------------------------
PASSWORD_MIN_LENGTH=12

# --- Account lockout (NFR-SE-06) --------------------------------------------
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=15

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
